{
  "name": "programming-handbook-it",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=www",
    "start": "turbo dev --filter=www",
    "build": "turbo build",
    "preview": "pnpm --filter www preview",
    "types:check": "turbo types:check",
    "lint": "pnpm exec oxlint .",
    "fmt": "pnpm exec oxfmt --write .",
    "fmt:check": "pnpm exec oxfmt --check .",
    "generate-types": "pnpm --filter www generate-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.5.8"
  },
  "overrides": {
    "vite": "^7"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro,css}": [
      "pnpm run fmt:check",
      "pnpm run lint"
    ],
    "*.{yml,yaml,md,mdx}": [
      "pnpm run fmt:check"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
