{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "types:check": {
      "dependsOn": ["^types:check"],
      "outputs": []
    },
    "generate-types": {
      "cache": false,
      "outputs": ["worker-configuration.d.ts"]
    }
  }
}
