---
import MobileMenuFooter from "@astrojs/starlight/components/MobileMenuFooter.astro";
import SidebarSublist from "@astrojs/starlight/components/SidebarSublist.astro";

const { sidebar = [] } = Astro.locals.starlightRoute;
const filteredSidebar = getSidebarContentForSection(
  sidebar,
  Astro.url.pathname,
);

function getSidebarSection(pathname: string) {
  const [, section] = pathname.split("/");
  return section?.toLowerCase() ?? "";
}

function getSidebarContentForSection(sidebar: unknown, pathname: string) {
  if (!Array.isArray(sidebar)) {
    return [];
  }

  const section = getSidebarSection(pathname);
  if (!section) {
    return [];
  }

  const entry = sidebar.find(
    (item) => String(item?.label).toLowerCase() === section,
  );
  if (!entry) {
    return [];
  }

  return entry.type === "group" ? (entry.entries ?? []) : [entry];
}
---

<SidebarSublist sublist={filteredSidebar} />

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>
