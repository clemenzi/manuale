---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { LinkButton } from "@astrojs/starlight/components";
---

<StarlightPage
  frontmatter={{
    title: "Pagina non trovata",
    head: [{ tag: "meta", attrs: { name: "robots", content: "noindex" } }],
  }}
>
  <p>
    La pagina che hai cercato non esiste o è stata spostata. Puoi tornare alla
    documentazione e continuare da uno dei manuali principali.
  </p>

  <LinkButton href="/python" variant="primary">
    Manuale di Python
  </LinkButton>
  <LinkButton href="/cpp" variant="secondary">
    Manuale di C++
  </LinkButton>
</StarlightPage>
