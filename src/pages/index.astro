---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { LinkButton } from '@astrojs/starlight/components';
---

<StarlightPage
  frontmatter={{
    title: "Handbook di Programmazione",
  }}
>
  <p>
    Benvenuto nel handbook di programmazione scritto per neofiti, qui troverai
    guide per iniziare. Questo handbook non può essere usato singolarmente come unico riferimento ma è pensato per essere affiancato a corsi, video o altre risorse. Se vuoi contribuire o hai suggerimenti, non esitare a contattarmi!
  </p>

  <LinkButton href="/python" variant="primary">
    Handbook di Python
  </LinkButton>
  <LinkButton href="/cpp" variant="primary">
    Handbook di C++
  </LinkButton>
</StarlightPage>
