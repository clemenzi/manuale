{
	"compatibility_date": "2026-04-16",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
	"name": "manuale",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
    "not_found_handling": "404-page"
	},
	"observability": {
		"enabled": true
	}
}
